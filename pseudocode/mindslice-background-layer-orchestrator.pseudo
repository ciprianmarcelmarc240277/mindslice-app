    parameters: parsedSlice: ParsedSliceObject, conceptualPreset: ConceptualPresetOutput, canvas: BackgroundOrchestratorCanvas, renderSettings: BackgroundOrchestratorRenderSettings = {}, registry?: BackgroundRegistryLike,

