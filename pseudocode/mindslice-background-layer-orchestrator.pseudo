PURPOSE:
    Select and configure the active background layer module for a parsed slice using conceptual preset, canvas, render settings, and optional registry adapter.
    confirmed_by:
        - exported_main_function:runBackgroundOrchestratorV2
        - output_type:BackgroundLayerSelectionV2
        - imported_dependency:concept-background-module-registry-system

INPUT:
    - parsedSlice: ParsedSliceObject
    - conceptualPreset: ConceptualPresetOutput
    - canvas: BackgroundOrchestratorCanvas
    - renderSettings: BackgroundOrchestratorRenderSettings = {}
    - registry?: BackgroundRegistryLike

OUTPUT:
    status: confirmed
    confirmed_by:
        - main_return_type: BackgroundLayerSelectionV2 | BackgroundOrchestratorFailure
        - success_return_fields: active_kind, module, grammar_profile, seed, density, opacity, settings, canvas, render_settings, reason
        - failure_return_fields: status, message

STATE:
    - implemented
    - active
    - Background / Pattern / Grammar
    - role:orchestration
    - version:implicit_v1
    - non-rendering_if_not_renderer
    - renderer_passive_if_renderer

