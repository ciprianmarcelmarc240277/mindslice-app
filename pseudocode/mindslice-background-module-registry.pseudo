        - LIST
        - MATCH
        - REGISTER_DEFAULTS
        - RUN

DATA_CONTRACT:
    receives:
        status: confirmed
        evidence:
            - input.registry_action: BackgroundRegistryAction
            - input.module_definition?: BackgroundModuleDefinition
            - input.background_kind?: BackgroundModuleKind
            - input.parsed_slice?: ParsedSliceObject
            - input.conceptual_preset?: ConceptualPresetOutput
            - input.render_settings?: BackgroundRegistryRenderSettings
    emits:
        status: confirmed
        evidence:
            - BackgroundRegistryFailure
            - BackgroundRegistryMatch
            - BackgroundModuleDefinition
            - modules registry object
            - exported constants PatternInferRules, TriangulationInferRules, FlatAbstractInferRules, IsometricInferRules, ZigZagInferRules, RetroGridInferRules
            - exported constants REGISTER, GET, LIST, MATCH, REGISTER_DEFAULTS, RUN
    mutates:
        status: confirmed_internal_registry_mutation
        evidence:
            - registerBackgroundModule assigns modules[moduleDefinition.kind] = moduleDefinition
            - registerDefaultBackgroundModules registers default background module definitions
            - module file calls registerDefaultBackgroundModules() at module load
    side_effects:
        status: confirmed_module_level_registry_initialization
        evidence:
            - module-level modules object is initialized and populated by registerDefaultBackgroundModules()
            - no file writes, network calls, DOM mutation, logging, or direct render calls detected in registry RUN path
    contract_status: confirmed_from_typescript_structure

FAIL:
    confirmed_failure_behavior_present
    confirmed_by:
        - validateBackgroundModule returns MISSING_BACKGROUND_KIND
        - validateBackgroundModule returns UNSUPPORTED_BACKGROUND_KIND
        - validateBackgroundModule returns INVALID_BACKGROUND_MODULE_CONTRACT
        - getBackgroundModule returns BACKGROUND_MODULE_NOT_FOUND
        - matchBackgroundModule returns NO_BACKGROUND_MODULES_REGISTERED
        - runBackgroundModuleRegistryV1 returns MISSING_MODULE_DEFINITION, MISSING_BACKGROUND_KIND, MISSING_MATCH_CONTEXT, or UNKNOWN_REGISTRY_ACTION

CONSTRAINTS:
