        - BackgroundModuleKind
        - BackgroundRegistryRenderSettings
        - BackgroundInferRules
        - BackgroundModuleDefinition
        - BackgroundRegistryFailure
        - BackgroundRegistryMatch
        - BackgroundRegistryAction

    exported_helper_functions:
