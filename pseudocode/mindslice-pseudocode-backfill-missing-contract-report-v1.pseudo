MODULE MindSlice_PseudocodeBackfillMissingContractReport_v1

PURPOSE:
    List contract fields that could not be confirmed during pseudocode backfill.

SUMMARY:
    checked_implemented_modules: 97
    status: review_required

INPUT:
- generated_backfill_pseudocode_files
- extracted_contract_hints
- module_registry_index
- required_contract_fields

OUTPUT:
- missing_contract_report
- checked_implemented_modules
- modules_requiring_contract_review
- missing_contract_fields_by_module

STATE:
- report
- read-only
- non-rendering
- non-executing
- contract-audit
- backfill-safe

FUNCTION RUN:

    VALIDATE input

    missing_contract_report = BUILD_MISSING_CONTRACT_REPORT(
        generated_backfill_pseudocode_files,
        extracted_contract_hints,
        required_contract_fields
    )

    RETURN {
        missing_contract_report: missing_contract_report,
        checked_implemented_modules: COUNT generated_backfill_pseudocode_files,
        modules_requiring_contract_review: EXTRACT_MODULES_WITH_MISSING_CONTRACTS(missing_contract_report),
        missing_contract_fields_by_module: GROUP_MISSING_FIELDS_BY_MODULE(missing_contract_report)
    }

HELPERS:

FUNCTION BUILD_MISSING_CONTRACT_REPORT(files, hints, required_fields):
    RETURN recorded MISSING_CONTRACTS entries

FUNCTION EXTRACT_MODULES_WITH_MISSING_CONTRACTS(report):
    RETURN all modules WHERE missing fields not empty

FUNCTION GROUP_MISSING_FIELDS_BY_MODULE(report):
    RETURN map module_name TO missing fields

FAIL:
IF generated_backfill_pseudocode_files is missing:
    RETURN FAIL "Missing required input: generated_backfill_pseudocode_files"

IF required_contract_fields is missing:
    RETURN FAIL "Missing required input: required_contract_fields"

IF report attempts to invent contracts:
    RETURN FAIL "Missing contract report cannot invent contracts"

IF report attempts to generate implementation code:
    RETURN FAIL "Missing contract report cannot generate implementation code"

CONSTRAINTS:
- No TypeScript
- No React
- No CSS
- No implementation code
- Report is read-only
- Report does not execute modules
- Report does not render
- Missing fields remain missing until confirmed
- Unknown fields must enter manual review
- Existing modules are preserved
- Renderer does not think
- Renderer only draws

