DATA_CONTRACT:
    receives:
        - ThoughtState
        - ColorPaletteState
        - LiveInterference
        - ThoughtMemoryEntry[]
        - generated form through helper applyMergedVisualOutputToArtComposition
        - composition layout through helper applyMergedVisualOutputToArtComposition
        - color palette through helper applyMergedVisualOutputToArtComposition
    emits:
        - art composition concept
        - ArtCompositionRuntime
        - ArtCompositionScores
