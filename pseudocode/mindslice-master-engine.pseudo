        - MindSlice_Formation
        - MindSlice_InputEngine
        - MindSlice_Meta
        - MindSlice_Interpretation
        - MindSlice_Validation
        - MindSlice_ThoughtSceneEngine
        - MindSlice_MindsliceTypes

MODULE_CLASSIFICATION:
    category: Core Concept Engines
    role: engine
    version: implicit_v1
    lifecycle: active
    can_render: false
    can_decide_logic: true
    requires_manual_review: false

FUNCTION RUN:
    implementation_function: runMasterEngine
    parameters: request: RunMasterEngineRequest

HELPERS:
    exported_types:
        - MasterIdentityContext
        - MasterSliceState
        - MasterConcept
        - RunMasterEngineRequest
        - RunMasterEngineResult

    exported_helper_functions:
        - handleIdentity
        - handleInput
        - applyMasterContamination
        - buildPipeline
        - executePipeline
        - buildMasterConcept
        - applyInfluence
        - validateMasterConcept
        - refineOrFail
        - isCanonicalConcept
        - buildDisplay
        - masterLaw

    exported_constants:
        - none_confirmed

DATA_CONTRACT:
    receives:
        - RunMasterEngineRequest
        - UserProfile
        - ThoughtState
        - HistoryEntry[]
        - ThoughtMemoryEntry[]
        - LiveInterference
        - CanonInfluenceContext
        - ClockDisplayState
    emits:
        - display output
        - master pipeline list
        - memory
        - canonical flag
        - notes
        - fail result with reason and notes
    mutates: none_detected
    side_effects:
        - reads current system time indirectly through InputEngine createSlice
    contract_status: confirmed_from_typescript_structure

FAIL:
    - No thrown failure confirmed.
    - Returns fail input_failure when input slice creation fails.
    - Returns fail pipeline_failure when pipeline execution returns null.
    - Returns fail validation_failure when concept validation and refine cycle fail.
    - Returns fail master_law_rejection when concept does not modify system or fails validation.

CONSTRAINTS:
    - Pseudocode backfill only.
    - Do not implement from this file without manual contract review.
    - Do not invent missing contracts.
    - Preserve implemented module identity.
    - Preserve version coexistence.
    - Renderer does not think.
    - Renderer only draws.
